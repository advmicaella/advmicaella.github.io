---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Informação jurídica clara sobre direito imobiliário em Rondônia — Micaella Dallagnolli Freitas, Advogada OAB/RO 14.891' } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalURL = new URL(currentPath, Astro.site);
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Micaella Dallagnolli Freitas</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <!-- Open Graph -->
  <meta property="og:title" content={`${title} — Micaella Dallagnolli Freitas`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:site_name" content="Micaella Dallagnolli Freitas — Advogada" />
  <!-- Twitter/X Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={`${title} — Micaella Dallagnolli Freitas`} />
  <meta name="twitter:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" title="Blog Jurídico — Micaella Dallagnolli Freitas" href="/rss.xml" />
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="header-brand">
        <span class="brand-name">Micaella Dallagnolli Freitas</span>
        <span class="brand-subtitle">Advogada · OAB/RO 14.891 · Regularização Imobiliária</span>
      </a>
      <nav class="site-nav" aria-label="Navegação principal">
        <a href="/" aria-current={currentPath === '/' ? 'page' : undefined}>Início</a>
        <a href="/blog" aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}>Blog</a>
        <a href="/sobre" aria-current={currentPath === '/sobre' ? 'page' : undefined}>Sobre</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <a href="https://wa.me/5569992740200" target="_blank" rel="noopener" class="whatsapp-fab" aria-label="Falar no WhatsApp">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <p class="footer-name">Micaella Dallagnolli Freitas</p>
        <p>Advogada — OAB/RO 14.891</p>
        <p>Porto Velho, Rondônia</p>
      </div>
      <div class="footer-legal">
        <p>Este site tem caráter exclusivamente informativo e educativo. O conteúdo publicado não constitui consultoria ou orientação jurídica individualizada.</p>
