---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  excerpt: string;
  categoria: string;
  tags: string[];
}

const { title, date, excerpt, categoria, tags } = Astro.props;

const dataFormatada = date.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---
<BaseLayout title={title} description={excerpt}>
  <div class="page-header">
    <div class="page-header-inner">
      <nav class="breadcrumb" aria-label="Caminho">
        <a href="/">Início</a>
        <span class="breadcrumb-sep">›</span>
        <a href="/blog">Blog</a>
        <span class="breadcrumb-sep">›</span>
        <span>{title}</span>
      </nav>
    </div>
  </div>

  <div class="section">
    <div class="container-narrow">
      <article>
        <header class="post-header">
          <div class="post-header-meta">
            <span class="categoria-badge">{categoria}</span>
            <span class="post-date">{dataFormatada}</span>
          </div>
          <h1>{title}</h1>
          {tags.length > 0 && (
            <div class="tags-list">
              {tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </header>

        <div class="prose">
          <slot />
        </div>
      </article>

      <a href="/blog" class="back-link">← Voltar ao Blog</a>
    </div>
  </div>
</BaseLayout>
