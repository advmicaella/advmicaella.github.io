---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const postDestaque = posts[0];
const postsRecentes = posts.slice(1, 4);

function formatarData(date: Date) {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
}
---
<BaseLayout title="Direito Imobiliário em Rondônia">
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <p class="hero-subtitle">Blog Jurídico · Porto Velho, Rondônia</p>
      <h1>Direito Imobiliário<br />em Rondônia</h1>
      <p class="hero-desc">
        Informação jurídica clara e confiável para quem tem imóvel em Porto Velho e Rondônia.
        Regularização, usucapião, ITBI, cartório e mais.
      </p>
      <div class="hero-cta">
        <a href="/blog" class="btn btn-primary">Ver artigos</a>
        <a href="/sobre" class="btn btn-outline">Sobre a advogada</a>
      </div>
      <div class="hero-lawyer">
        <strong>Micaella Dallagnolli Freitas</strong> — Advogada · OAB/RO 14.891 · Regularização Imobiliária
      </div>
      <a href="https://maps.app.goo.gl/rxx5deCinYd9Nebx9" target="_blank" rel="noopener" class="google-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        <span class="google-stars">★★★★★</span>
        <span class="google-score">5,0</span>
        <span class="google-count">(64 avaliações)</span>
      </a>
    </div>
  </section>

  <!-- DESTAQUE -->
  {postDestaque && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <div>
            <h2 class="section-title">Artigo em destaque</h2>
            <p class="section-desc">O mais recente conteúdo do blog</p>
          </div>
          <a href="/blog" class="btn btn-ghost">Ver todos →</a>
        </div>
        <a href={`/blog/${postDestaque.slug}`} style="text-decoration: none; display: block;">
          <div class="featured-post">
            <p class="featured-label">Destaque</p>
            <div class="post-meta">
              <span class="categoria-badge">{postDestaque.data.categoria}</span>
              <span class="post-date">{formatarData(postDestaque.data.date)}</span>
            </div>
            <h3 class="post-title" style="font-size: 1.45rem;">{postDestaque.data.title}</h3>
            <p class="post-excerpt">{postDestaque.data.excerpt}</p>
            <div class="tags-list" style="margin-top: 1rem;">
              {postDestaque.data.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- ÚLTIMOS ARTIGOS -->
  {postsRecentes.length > 0 && (
    <section class="section" style="padding-top: 0;">
      <div class="container">
        <div class="section-header">
          <div>
            <h2 class="section-title">Últimos artigos</h2>
            <p class="section-desc">Conteúdo educativo sobre direito imobiliário</p>
          </div>
          <a href="/blog" class="btn btn-ghost">Ver todos →</a>
        </div>
        <div class="posts-grid">
          {postsRecentes.map(post => (
            <div class="card">
              <div class="card-body">
                <div class="post-meta">
                  <span class="categoria-badge">{post.data.categoria}</span>
                  <span class="post-date">{formatarData(post.data.date)}</span>
                </div>
                <h3 class="post-title">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </h3>
                <p class="post-excerpt">{post.data.excerpt}</p>
              </div>
              <div class="card-footer">
                <a href={`/blog/${post.slug}`} class="btn btn-ghost">Ler artigo →</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- SOBRE -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="about-card" style="display: grid; grid-template-columns: auto 1fr; gap: 2rem; align-items: start;">
        <div>
          <div class="about-avatar">MDF</div>
        </div>
        <div>
          <h2 style="margin-bottom: .5rem;">Sobre a advogada</h2>
          <p style="color: var(--text-light); font-size: .95rem; margin-bottom: 1rem;">
            Micaella Dallagnolli Freitas é advogada inscrita na OAB/RO sob o número 14.891,
            com atuação voltada ao direito imobiliário e à regularização fundiária em Porto Velho
            e no estado de Rondônia. O conteúdo deste blog é produzido com o objetivo de democratizar
            o acesso à informação jurídica para cidadãos que possuem ou pretendem adquirir imóveis na região.
          </p>
          <a href="/sobre" class="btn btn-ghost">Conheça mais →</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
