---
import BaseLayout from '../layouts/BaseLayout.astro';

const publicacoes = [
  {
    tipo: 'Artigo Científico · TCC',
    titulo: 'Democratização do Ensino de Direitos Humanos no Ensino Fundamental: Desafios e Oportunidades para a Formação de Cidadãos Conscientes',
    veiculo: 'Revista FT — Ciências Sociais Aplicadas, Ed. 139, Out. 2024',
    descricao: 'Trabalho de Conclusão de Curso, escrito com Marcell Costa Leal e orientado pela Profª. Jennifer Alves Rates Gomes, sobre os desafios e oportunidades para incluir o ensino de direitos humanos na educação básica brasileira.',
    link: 'https://revistaft.com.br/democratizacao-do-ensino-de-direitos-humanos-no-ensino-fundamental-desafios-e-oportunidades-para-a-formacao-de-cidadaos-conscientes/',
  },
  {
    tipo: 'Artigo Científico',
    titulo: 'Soft Skills na Advocacia Contemporânea e nos Meios Consensuais de Resolução de Conflitos',
    veiculo: 'International Journal of Digital Law, v. 2, n. 3 (2021)',
    descricao: 'Artigo escrito com o Prof. Moisés de Almeida Góes sobre como o desenvolvimento de competências comportamentais (soft skills) auxilia advogados a atuar de forma mais eficaz nos meios consensuais de resolução de conflitos.',
    link: 'https://journal.nuped.com.br/index.php/revista/article/view/v2n3freitas2021',
  },
  {
    tipo: 'Anais de Congresso',
    titulo: 'Desenvolvimento e Democratização do Ensino de Direitos Humanos no Brasil',
    veiculo: 'VI Congresso Internacional de Direitos Humanos de Coimbra, v. 6, n. 1 (2021)',
    descricao: 'Trabalho apresentado com o Prof. Fábio Santos (PUCPR) no Simpósio Temático 65 do congresso realizado em Coimbra, Portugal, sobre a democratização do ensino de direitos humanos como mecanismo de promoção do desenvolvimento.',
    link: 'http://trabalhoscidhcoimbra.com/ojs/index.php/anaiscidhcoimbra/article/view/948',
  },
  {
    tipo: 'Colaboração Institucional',
    titulo: 'Estágio em Órgão Público ou em Escritório de Advocacia? Um Relato de Experiências em Estágios Jurídicos',
    veiculo: 'Manual do Estágio na Advocacia — OAB/RO',
    descricao: 'Texto de orientação a acadêmicos de Direito sobre como escolher entre estágio em órgão público ou em escritório de advocacia, publicado no manual da Ordem dos Advogados do Brasil — Seccional Rondônia.',
    link: 'https://www.oab-ro.org.br/gerenciador/data/uploads/2023/06/Manual-do-Estagiario-na-Advocacia-A4-V1-1.pdf',
  },
];
---
<BaseLayout
  title="Publicações"
  description="Produção acadêmica e institucional de Micaella Dallagnolli Freitas — TCC, artigos científicos, congressos e colaborações com a OAB/RO."
>
  <div class="page-header">
    <div class="page-header-inner">
      <h1>Publicações</h1>
      <p>Produção acadêmica e institucional</p>
    </div>
  </div>

  <div class="section">
    <div class="container-narrow">
      <p style="color: var(--text-light); margin-bottom: 2rem;">
        Trabalhos acadêmicos e colaborações institucionais desenvolvidos ao longo da minha
        formação e atuação como advogada.
      </p>

      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        {publicacoes.map(pub => (
          <a href={pub.link} target="_blank" rel="noopener" style="text-decoration: none; display: block;">
            <div class="card">
              <div class="card-body">
                <span class="categoria-badge" style="margin-bottom: .75rem; display: inline-block;">{pub.tipo}</span>
                <h3 class="post-title" style="font-size: 1.15rem;">{pub.titulo}</h3>
                <p style="font-family: 'Montserrat',sans-serif; font-size: .8rem; color: var(--gold); font-weight: 700; margin-bottom: .6rem;">{pub.veiculo}</p>
                <p class="post-excerpt">{pub.descricao}</p>
              </div>
              <div class="card-footer">
                <span class="btn btn-ghost">Ler publicação →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
